{
  "name": "@radicle-it/expresql",
  "version": "2.0.0",
  "description": "ExpreSQL — ESQL shorthand to DDL, ERD and PL/SQL scaffolding (fork of @oracle/quicksql)",
  "main": "./dist/expresql.js",
  "type": "module",
  "exports": {
    ".": "./dist/expresql.js"
  },
  "engines": {
    "node": ">=16"
  },
  "bin": {
    "expresql": "bin/index.js"
  },
  "config": {
    "ddlLibraryName": "expresql",
    "ddlLibraryFileName": "expresql"
  },
  "scripts": {
    "build": "run-p build:ddl build:ddl-oracle build:ddl-db2 && npm run build:mle && npm run build:web",
    "prebuild": "node -e \"const fs=require('fs');fs.rmSync('./dist',{recursive:true,force:true});fs.mkdirSync('./dist',{recursive:true});fs.copyFileSync('./node_modules/@antv/x6/dist/index.js','./dist/antv-x6.min.js');\"",
    "build:ddl": "cross-env TARGET_LIBRARY=DDL vite build",
    "test": "./test/regression_test.js",
    "test:ts": "vitest run",
    "test:ts:watch": "vitest",
    "lint:markdown": "markdownlint-cli2 *.md, doc/**/*.md",
    "lint": "run-p lint:*",
    "example-cli": "./examples/cli.js",
    "postversion": "run-s build",
    "build:mle": "node scripts/build-mle.mjs && node scripts/generate-mle-sql.mjs",
    "build:ddl-oracle": "cross-env TARGET_LIBRARY=DDL-ORACLE vite build",
    "build:ddl-db2": "cross-env TARGET_LIBRARY=DDL-DB2 vite build",
    "build:web": "vite build --config vite.apex.config.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/radicle-it/expresql.git"
  },
  "keywords": [
    "ExpreSQL",
    "Oracle",
    "ExpreSQL",
    "SQL",
    "DDL",
    "ERD",
    "Diagram"
  ],
  "files": [
    "assets",
    "!(CONTRIBUTING).md",
    "doc/user",
    "dist"
  ],
  "license": "UPL-1.0",
  "dependencies": {
    "@antv/x6": "^2.18.1",
    "chance": "^1.1.11"
  },
  "bundledDependencies": true,
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.42.0",
    "markdownlint-cli2": "^0.22.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "bundleDependencies": [
    "chance"
  ]
}
